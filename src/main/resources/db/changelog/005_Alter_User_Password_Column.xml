<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="1" author="Devin">
        <comment>Alter password column to support SHA-256 hex hashes (64 chars)</comment>
        <modifyDataType tableName="user" columnName="password" newDataType="VARCHAR(64)"/>
        <rollback>
            <modifyDataType tableName="user" columnName="password" newDataType="VARCHAR(20)"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
