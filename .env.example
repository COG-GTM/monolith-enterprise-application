# Devin API Configuration
# Copy this file to .env and fill in your values.
#
# To obtain a Devin service user API key:
#   1. Go to https://app.devin.ai → Settings → Service Users
#   2. Create a service user (or use an existing one)
#   3. Assign a role with ManageOrgSessions permission
#   4. Generate an API key (starts with cog_)
#
# See: https://docs.devin.ai/api-reference/authentication

DEVIN_API_KEY=cog_your_service_user_api_key_here

# (Optional) Your Devin organization ID.
# Find it in Settings → Organization details.
# If omitted, the API auto-resolves the org from your service user scope.
DEVIN_ORG_ID=

# The GitHub repository identifier for this project (owner/repo format).
# Used when creating remote Devin sessions so Devin clones the correct repo.
DEVIN_REPO=COG-GTM/monolith-enterprise-application
